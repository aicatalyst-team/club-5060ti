{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/5p00kyy/club-5060ti/data/schema/benchmark-result.schema.json",
  "title": "club-5060ti benchmark result",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "timestamp_utc",
    "source",
    "promotion_level",
    "hardware",
    "runtime",
    "model",
    "serving",
    "benchmark",
    "metrics"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]+$"
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "required": ["type", "label"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["seed", "community", "imported", "external"]
        },
        "label": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "promotion_level": {
      "type": "string",
      "enum": ["exploratory", "recipe", "benchmark", "verified", "deprecated"]
    },
    "hardware": {
      "type": "object",
      "required": ["gpu_count", "gpu_model", "vram_per_gpu_gb"],
      "properties": {
        "gpu_count": {
          "type": "integer",
          "minimum": 1
        },
        "gpu_model": {
          "type": "string"
        },
        "vram_per_gpu_gb": {
          "type": "number",
          "minimum": 1
        },
        "driver": {
          "type": "string"
        },
        "cpu": {
          "type": "string"
        },
        "host_ram_gb": {
          "type": "number"
        },
        "inference_ram_gb": {
          "type": "number"
        },
        "pcie": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "runtime": {
      "type": "object",
      "required": ["engine"],
      "properties": {
        "engine": {
          "type": "string",
          "enum": ["llama.cpp", "ik_llama.cpp", "BeeLlama", "vLLM", "SGLang", "other"]
        },
        "version": {
          "type": "string"
        },
        "commit": {
          "type": "string"
        },
        "build": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "model": {
      "type": "object",
      "required": ["id", "family", "quant"],
      "properties": {
        "id": {
          "type": "string"
        },
        "family": {
          "type": "string"
        },
        "architecture": {
          "type": "string",
          "enum": ["dense", "moe", "hybrid", "unknown"]
        },
        "parameter_class": {
          "type": "string"
        },
        "active_parameter_class": {
          "type": "string"
        },
        "quant": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "file_size_mb": {
          "type": "number"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "serving": {
      "type": "object",
      "properties": {
        "route": {
          "type": "string",
          "enum": ["server", "cli", "container", "unknown"]
        },
        "context_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "batch_size": {
          "type": "integer",
          "minimum": 1
        },
        "ubatch_size": {
          "type": "integer",
          "minimum": 1
        },
        "kv_cache_k": {
          "type": "string"
        },
        "kv_cache_v": {
          "type": "string"
        },
        "tensor_parallel": {
          "type": "string"
        },
        "split_mode": {
          "type": "string"
        },
        "gpu_layers": {
          "type": "string"
        },
        "speculation": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string"
            },
            "draft_n": {
              "type": "integer"
            },
            "acceptance_rate": {
              "type": "number"
            },
            "notes": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "thinking": {
          "type": "string",
          "enum": ["on", "off", "unknown"]
        },
        "launch": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "benchmark": {
      "type": "object",
      "required": ["prompt_set"],
      "properties": {
        "prompt_set": {
          "type": "string",
          "enum": ["short-chat", "code-generate", "agent-tool", "long-retrieval", "vision-smoke", "legacy", "custom"]
        },
        "configured_context_tokens": {
          "type": "integer"
        },
        "actual_prompt_tokens": {
          "type": "integer"
        },
        "generated_tokens": {
          "type": "integer"
        },
        "runs": {
          "type": "integer",
          "minimum": 1
        },
        "warmups": {
          "type": "integer",
          "minimum": 0
        },
        "stream": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "metrics": {
      "type": "object",
      "properties": {
        "prompt_tok_s": {
          "type": "number"
        },
        "decode_tok_s": {
          "type": "number"
        },
        "end_to_end_tok_s": {
          "type": "number"
        },
        "wall_seconds": {
          "type": "number"
        },
        "ttft_seconds": {
          "type": "number"
        },
        "load_seconds": {
          "type": "number"
        },
        "vram_used_mb": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "quality_score": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "caveats": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
